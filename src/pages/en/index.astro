---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Kiribas | Offshore Company Formation & Licensing in Kiribati"
  description="Tax-advantaged IBC registration and KIFA regulatory licensing in the Republic of Kiribati. Offshore company formation, banking, gaming, crypto, FX, and insurance licensing."
  lang="en"
>
  <Fragment slot="logo">Kiribas</Fragment>
  <Fragment slot="footer-name">Kiribas</Fragment>

  <section class="hero">
    <img src="/images/logo.webp" alt="Logo" class="hero-logo" width="200" height="auto" />
    <h1>Kiribas</h1>
    <p class="tagline">Offshore Company Formation & Licensing in Kiribati</p>
    <p>Tax-Advantaged IBC Registration and KIFA Regulatory Licensing</p>
  </section>

  <div class="ad-slot">Ad Space - Google AdSense</div>

  <div class="card-grid">
    <article class="card">
      <h2>IBC Incorporation</h2>
      <p>Offshore IBC incorporation through kiribas.net. Comprehensive document preparation including incorporation applications, memorandum & articles, compliance checklists.</p>
    </article>
    <article class="card">
      <h2>KIFA Licensing</h2>
      <p>Regulatory licensing for banking, gaming, crypto, FX, and insurance through the Kiribati International Financial Authority.</p>
    </article>
    <article class="card">
      <h2>Combined Packages</h2>
      <p>Dual registration handling both IBC incorporation and KIFA licensing simultaneously with a single point of contact.</p>
    </article>
    <article class="card">
      <h2>Pricing</h2>
      <p>$6,000 USD per year flat tax on profits. No corporate income tax, capital gains tax, or withholding taxes. Pro-rated for mid-year incorporation.</p>
    </article>
    <article class="card">
      <h2>Process</h2>
      <p>Initial inquiry, custom assessment, document preparation, submission and follow-up. Typical turnaround 2-6 weeks with dedicated account management.</p>
    </article>
    <article class="card">
      <h2>Crypto Payments</h2>
      <p>Accepts BTC, ETH, SOL, USDC, and USDT. Stablecoins preferred.</p>
    </article>
  </div>

  <div class="ad-slot">Ad Space - Google AdSense</div>

  <section class="registration-info">
    <h2>Contact & Registration</h2>
    <p><strong>Address:</strong> Gerom str, 22108 London (KI)</p>
    <p><strong>Phone:</strong> +37022665869</p>
    <p class="disclaimer">Not an official government body. Authorized Agent services only.</p>
  </section>

  <div class="ad-slot">Ad Space - Google AdSense</div>
</BaseLayout>

<style>
  .hero-logo {
    max-width: 200px;
    height: auto;
    margin-bottom: 20px;
    border-radius: 8px;
  }
  .tagline {
    font-size: 1.4rem;
    font-weight: 600;
    opacity: 1;
    margin-bottom: 8px;
  }
  .registration-info {
    background: white;
    border-radius: 8px;
    padding: 32px;
    margin-top: 32px;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
    text-align: center;
  }
  .registration-info h2 {
    margin-bottom: 16px;
    color: #1a1a2e;
  }
  .registration-info p {
    margin: 6px 0;
    color: #555;
  }
  .registration-info .disclaimer {
    margin-top: 16px;
    font-size: 0.85rem;
    font-style: italic;
    color: #888;
  }
</style>
